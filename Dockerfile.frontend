FROM node:20-alpine AS builder
WORKDIR /app
COPY hra-frontend/package.json .
RUN npm install --legacy-peer-deps
COPY hra-frontend/ .
RUN npm run build

FROM nginx:alpine
RUN apk add --no-cache gettext
COPY --from=builder /app/dist /usr/share/nginx/html
COPY hra-frontend/nginx.conf.template /etc/nginx/conf.d/nginx.conf.template
EXPOSE 80
CMD ["/bin/sh", "-c", "envsubst '${PORT} ${BACKEND_URL}' < /etc/nginx/conf.d/nginx.conf.template > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]
